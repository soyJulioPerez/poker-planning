{
  "name": "poker-planning",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve web",
    "start:api": "nx serve realtime-api",
    "dev:api": "cross-env DYNAMODB_ENDPOINT=http://localhost:8000 AWS_REGION=us-east-2 TABLE_NAME=poker-planning-rooms nx serve realtime-api",
    "dev:db:up": "docker run -d --name dynamodb-local -p 8000:8000 amazon/dynamodb-local:latest",
    "dev:db:create-table": "aws dynamodb create-table --table-name poker-planning-rooms --attribute-definitions AttributeName=PK,AttributeType=S AttributeName=SK,AttributeType=S --key-schema AttributeName=PK,KeyType=HASH AttributeName=SK,KeyType=RANGE --billing-mode PAY_PER_REQUEST --endpoint-url http://localhost:8000 --region us-east-2",
    "build": "nx build web",
    "build:api": "nx build realtime-api",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "test:e2e": "npm run e2e:db:up && nx e2e e2e",
    "test:e2e:aws": "cross-env E2E_TARGET=aws nx e2e e2e",
    "e2e:db:up": "(docker start dynamodb-local || docker run -d --name dynamodb-local -p 8000:8000 amazon/dynamodb-local:latest) && npm run dev:db:create-table || true"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "21.2.7",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/platform-server": "21.2.9",
    "@angular/router": "21.2.9",
    "@angular/ssr": "21.2.7",
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1079.0",
    "@aws-sdk/client-dynamodb": "^3.1079.0",
    "@aws-sdk/lib-dynamodb": "^3.1079.0",
    "express": "^4.21.2",
    "rxjs": "~7.8.0",
    "ws": "^8.21.0",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.2.0",
    "@analogjs/vitest-angular": "2.2.0",
    "@angular-devkit/core": "21.2.7",
    "@angular-devkit/schematics": "21.2.7",
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.9",
